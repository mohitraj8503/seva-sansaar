# Firebase Admin (same pattern as A3 – used by API routes + optional Firestore)
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Google Maps JavaScript API key (Places Autocomplete on list-business / owner listing)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Admin dashboard API (same value for server + browser; keep secret in production)
# ADMIN_API_KEY=
# NEXT_PUBLIC_ADMIN_API_KEY=

# Notifications (C9) — optional
# RESEND_API_KEY=
# RESEND_FROM=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# ADMIN_ALERT_EMAIL=

# Firebase client (for authenticated bookings/reviews)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
